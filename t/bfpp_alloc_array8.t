#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# alloc_array8 - error no arguments
spew("$test.in", "alloc_array8");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: expected '(' after macro name 'alloc_array8'
END

