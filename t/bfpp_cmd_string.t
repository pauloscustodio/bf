#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# cmp_string - error no arguments
spew("$test.in", "cmp_string");
capture_nok("bfpp $test.in", <<END);
$test.in:1:11: error: expected '(' after macro name 'cmp_string'
END

# cmp_string - error empty arguments
spew("$test.in", "cmp_string()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: macro 'cmp_string' expects STR1, STR2 strings and result
END

# cmp_string - error too many arguments
spew("$test.in", "cmp_string(A,B,C,D)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:17: error: expected ')' at end of macro call, found ','
END

# cmp_string - wrong type of arguments
spew("$test.in", "cmp_string(1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: expected ',' in macro argument list
END

# cmp_string - wrong type of arguments
spew("$test.in", "cmp_string(1,2,3,4)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:17: error: expected ')' at end of macro call, found ','
END

# cmp_string - wrong type of arguments
spew("$test.in", "alloc_array8(STR1, 5) alloc_array8(STR2, 5) cmp_string(STR2, 42, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:68: error: macro 'cmp_string' expects STR1, STR2 strings and result
END

# cmp_string - wrong type of arguments
spew("$test.in", "alloc_array8(STR1, 5) alloc_array8(STR2, 5) cmp_string(42, STR1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:68: error: macro 'cmp_string' expects STR1, STR2 strings and result
END

# cmp_string - wrong type of arguments
spew("$test.in", "alloc_array16(STR1, 5) alloc_array8(STR2, 5) cmp_string(STR1, STR2,1 )");
capture_nok("bfpp $test.in", <<END);
$test.in:1:71: error: array 'STR1' is not a alloc_array8() array
END

# cmp_string - wrong type of arguments
spew("$test.in", "alloc_array8(STR1, 5) alloc_array16(STR2, 5) cmp_string(STR1, STR2,1 )");
capture_nok("bfpp $test.in", <<END);
$test.in:1:71: error: array 'STR2' is not a alloc_array8() array
END

# cmp_string - wrong type of arguments
spew("$test.in", "alloc_cell8(STR1) alloc_array8(STR2, 5) cmp_string(STR1, STR2, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:41: error: array 'STR1' is not an alloc_array result
END

# cmp_string - wrong type of arguments
spew("$test.in", "alloc_array8(STR1, 5) alloc_cell8(STR2) cmp_string(STR1, STR2, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:41: error: array 'STR2' is not an alloc_array result
END

# cmp_string - use as reserved word
spew("$test.in", "#define cmp_string 1");
capture_nok("bfpp $test.in", <<END);
$test.in:1:9: error: cannot define macro 'cmp_string': reserved word
END

# alloc_array8, set string
spew("$test.in", <<END);
alloc_cell8(RESULT)
alloc_array8(STR2, 5)
alloc_array8(STR1, 5)
cmp_string(STR1, STR2, RESULT)
END
capture_ok("bfpp $test.in", <<END);
