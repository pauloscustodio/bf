#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# min8s - error no arguments
spew("$test.in", "min8s");
capture_nok("bfpp $test.in", <<END);
$test.in:1:6: error: expected '(' after macro name 'min8s'
END

# min8s - error empty arguments
spew("$test.in", "min8s()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:8: error: macro 'min8s' expects 2 arguments
END

# min8s - error too many arguments
spew("$test.in", "min8s(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:10: error: expected ')' at end of macro call, found ','
END

# min8s(a,b)
spew("$test.in", <<END);
alloc_cell8(A)
alloc_cell8(B)
min8s(A,B)
END
capture_ok("bfpp $test.in", <<END);
