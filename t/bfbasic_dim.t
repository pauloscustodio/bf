alloc_cell16(_BFB10)
set16(_BFB10, 1)
get_array16(A, _BFB10, _BFB9)
free_cell16(_BFB10)
print_cell16s(_BFB9)
free_cell16(_BFB9)
alloc_cell16(_BFB11)
alloc_cell16(_BFB12)
set16(_BFB12, 2)
get_array16(A, _BFB12, _BFB11)
free_cell16(_BFB12)
print_cell16s(_BFB11)
free_cell16(_BFB11)
alloc_cell16(_BFB13)
alloc_cell16(_BFB14)
set16(_BFB14, 1)
get_array16(B, _BFB14, _BFB13)
free_cell16(_BFB14)
print_cell16s(_BFB13)
free_cell16(_BFB13)
alloc_cell16(_BFB15)
alloc_cell16(_BFB16)
set16(_BFB16, 2)
get_array16(B, _BFB16, _BFB15)
free_cell16(_BFB16)
print_cell16s(_BFB15)
free_cell16(_BFB15)
END
run_ok("bfpp -o $test.bf $test.bfpp");
capture_ok("bf $test.bf", "2 4 3 6 ");

unlink_testfiles;
done_testing;
