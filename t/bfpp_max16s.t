#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# max16s - error no arguments
spew("$test.in", "max16s");
capture_nok("bfpp $test.in", <<END);
$test.in:1:7: error: expected '(' after macro name 'max16s'
END

# max16s - error empty arguments
spew("$test.in", "max16s()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:9: error: macro 'max16s' expects 2 arguments
END

# max16s - error too many arguments
spew("$test.in", "max16s(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:11: error: expected ')' at end of macro call, found ','
END

# max16s(a,b)
spew("$test.in", <<END);
alloc_cell16(A)
alloc_cell16(B)
max16s(A,B)
END
capture_ok("bfpp $test.in", <<END);
