#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# string_val16 - error no arguments
spew("$test.in", "string_val16");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: expected '(' after macro name 'string_val16'
END

# string_val16 - error empty arguments
spew("$test.in", "string_val16()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:15: error: macro 'string_val16' expects one NAME and one cell
END

# string_val16 - error too many arguments
spew("$test.in", "string_val16(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:17: error: expected ')' at end of macro call, found ','
END

# string_val16 - wrong type of arguments
spew("$test.in", "string_val16(0, 2)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:19: error: macro 'string_val16' expects one NAME and one cell
END

# string_val16 - wrong type of arguments
spew("$test.in", "alloc_cell16(A) string_val16(A, 2)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:17: error: array 'A' is not an alloc_array result
END

# string_val16 - wrong type of arguments
spew("$test.in", "alloc_array16(A, 10) string_val16(A, 2)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:40: error: array 'A' is not a alloc_array8() array
END

# string_val16 - print the given cells
spew("$test.in", <<END);
alloc_cell16(A)
alloc_array8(S, 10) set_string(S, "0")
string_val16(S, A)
END
capture_ok("bfpp $test.in", <<END);
