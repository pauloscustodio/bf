#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# format_cell8 - error no arguments
spew("$test.in", "format_cell8");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: expected '(' after macro name 'format_cell8'
END

# format_cell8 - error empty arguments
spew("$test.in", "format_cell8()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:15: error: macro 'format_cell8' expects one NAME and one cell
END

# format_cell8 - error too many arguments
spew("$test.in", "format_cell8(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:17: error: expected ')' at end of macro call, found ','
END

# format_cell8 - print the given cells
spew("$test.in", <<END);
alloc_array8(S, 10)
alloc_cell8(A)
format_cell8(S, A)
END
capture_ok("bfpp $test.in", <<END);
