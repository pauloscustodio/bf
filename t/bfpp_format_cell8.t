# print numbers
for my $A (0, 1, 12, 123, 127, 255) {
	spew("$test.in", <<END);
		alloc_array8(S, 10+1)
		alloc_cell8(A) set8(A, $A) 
		format_cell8(S, A)
		print_string(S)
END
	capture_ok("bfpp $test.in | bf", "$A ");
}

# buffer too small - no output
for my $A (0, 1, 12, 123, 127, 255) {
	spew("$test.in", <<END);
		alloc_array8(S, 1+1)
		alloc_cell8(A) set8(A, $A) 
		format_cell8(S, A)
		print_string(S)
END
	capture_ok("bfpp $test.in | bf", "");
}

unlink_testfiles;
done_testing;
