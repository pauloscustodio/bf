#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# append_string - error no arguments
spew("$test.in", "append_string");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: expected '(' after macro name 'append_string'
END

# append_string - error empty arguments
spew("$test.in", "append_string()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: macro 'append_string' expects DST and SRC strings
END

# append_string - error too many arguments
spew("$test.in", "append_string(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: expected ')' at end of macro call, found ','
END

# append_string - wrong type of arguments
spew("$test.in", "append_string(1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: expected ',' in macro argument list
END

# append_string - wrong type of arguments
spew("$test.in", "append_string(1,2,3)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: expected ')' at end of macro call, found ','
END

# append_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array8(DST, 5) append_string(DST, 42)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:65: error: macro 'append_string' expects DST and SRC strings
END

# append_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array8(DST, 5) append_string(42, SRC)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:65: error: macro 'append_string' expects DST and SRC strings
END

# append_string - wrong type of arguments
spew("$test.in", "alloc_array16(SRC, 5) alloc_array8(DST, 5) append_string(DST, SRC)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:67: error: array 'SRC' is not a alloc_array8() array
END

# append_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array16(DST, 5) append_string(DST, SRC)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:67: error: array 'DST' is not a alloc_array8() array
END

# append_string - wrong type of arguments
spew("$test.in", "alloc_cell8(SRC) alloc_array8(DST, 5) append_string(DST, SRC)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'SRC' is not an alloc_array result
END

# append_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_cell8(DST) append_string(DST, SRC)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'DST' is not an alloc_array result
END

# append_string - use as reserved word
spew("$test.in", "#define append_string 1");
capture_nok("bfpp $test.in", <<END);
$test.in:1:9: error: cannot define macro 'append_string': reserved word
END

# alloc_array8, set string
spew("$test.in", <<END);
alloc_array8(DST, 5)
alloc_array8(SRC, 5)
append_string(DST, SRC)
END
capture_ok("bfpp $test.in", <<END);
