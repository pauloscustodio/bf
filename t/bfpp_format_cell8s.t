# print numbers
for my $A (-128, -127, -98, -9, -1, 0, 1, 9, 98, 127) {
	spew("$test.in", <<END);
		alloc_array8(S, 10+1)
		alloc_cell8(A) set8(A, $A) 
		format_cell8s(S, A)
		print_string(S)
END
	capture_ok("bfpp $test.in | bf", "$A ");
}

# buffer too small - no output
for my $A (-128, -127, -98, -9, -1, 0, 1, 9, 98, 127) {
	spew("$test.in", <<END);
		alloc_array8(S, 1+1)
		alloc_cell8(A) set8(A, $A) 
		format_cell8s(S, A)
		print_string(S)
END
	capture_ok("bfpp $test.in | bf", "");
}

unlink_testfiles;
