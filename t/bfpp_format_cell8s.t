#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# format_cell8s - error no arguments
spew("$test.in", "format_cell8s");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: expected '(' after macro name 'format_cell8s'
END

# format_cell8s - error empty arguments
spew("$test.in", "format_cell8s()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: macro 'format_cell8s' expects one NAME and one cell
END

# format_cell8s - error too many arguments
spew("$test.in", "format_cell8s(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: expected ')' at end of macro call, found ','
END

# format_cell8s - print the given cells
spew("$test.in", <<END);
alloc_array8(S, 10)
alloc_cell8(A)
format_cell8s(S, A)
END
capture_ok("bfpp $test.in", <<END);
