#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# & with literal strings
spew("$test.bas", <<'END');
DIM A$(12)
LET A$ = "Hello " & "World!"
PRINT A$;
END
run_ok("bfbasic -o $test.bfpp $test.bas");
check_text_file("$test.bfpp", <<'END');
// Generated by bfbasic, see https://github.com/pauloscustodio/bf
alloc_array8(A$, 13)
alloc_array8(_BFB1$, 13)
alloc_array8(_BFB2$, 7)
set_string(_BFB2$, "Hello ")
alloc_array8(_BFB3$, 7)
set_string(_BFB3$, "World!")
set_string(_BFB1$, _BFB2$)
append_string(_BFB1$, _BFB3$)
free_array8(_BFB2$)
free_array8(_BFB3$)
set_string(A$, _BFB1$)
free_array8(_BFB1$)
print_string(A$)
END
run_ok("bfpp -o $test.bf $test.bfpp");
capture_ok("bf $test.bf", "Hello World!");

# & with variable strings
spew("$test.bas", <<'END');
DIM A$(12) : DIM B$(12) : DIM C$(12)
LET A$ = "Hello "
LET B$ = "World!"
LET C$ = A$ & B$
PRINT C$;
END
run_ok("bfbasic -o $test.bfpp $test.bas");
check_text_file("$test.bfpp", <<'END');
// Generated by bfbasic, see https://github.com/pauloscustodio/bf
alloc_array8(A$, 13)
alloc_array8(B$, 13)
alloc_array8(C$, 13)
set_string(A$, "Hello ")
set_string(B$, "World!")
alloc_array8(_BFB1$, 25)
set_string(_BFB1$, A$)
append_string(_BFB1$, B$)
set_string(C$, _BFB1$)
free_array8(_BFB1$)
print_string(C$)
END
run_ok("bfpp -o $test.bf $test.bfpp");
capture_ok("bf $test.bf", "Hello World!");

