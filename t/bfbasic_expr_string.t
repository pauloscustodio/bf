DIM A$(16)
LET A$ = "Hello "
LET A$ = " " & A$ & A$
PRINT A$;
END
run_ok("bfbasic -o $test.bfpp $test.bas");
check_text_file("$test.bfpp", <<'END');
// Generated by bfbasic, see https://github.com/pauloscustodio/bf
alloc_array8(A$, 17)
set_string(A$, "Hello ")
alloc_array8(_BFB1$, 34)
alloc_array8(_BFB2$, 18)
alloc_array8(_BFB3$, 2)
set_string(_BFB3$, " ")
set_string(_BFB2$, _BFB3$)
append_string(_BFB2$, A$)
free_array8(_BFB3$)
set_string(_BFB1$, _BFB2$)
append_string(_BFB1$, A$)
free_array8(_BFB2$)
set_string(A$, _BFB1$)
free_array8(_BFB1$)
print_string(A$)
END
