#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# max8s - error no arguments
spew("$test.in", "max8s");
capture_nok("bfpp $test.in", <<END);
$test.in:1:6: error: expected '(' after macro name 'max8s'
END

# max8s - error empty arguments
spew("$test.in", "max8s()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:8: error: macro 'max8s' expects 2 arguments
END

# max8s - error too many arguments
spew("$test.in", "max8s(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:10: error: expected ')' at end of macro call, found ','
END

# max8s(a,b)
spew("$test.in", <<END);
alloc_cell8(A)
alloc_cell8(B)
max8s(A,B)
END
capture_ok("bfpp $test.in", <<END);
