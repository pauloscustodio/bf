# run max8s(a,b)
for my $A (-127, -2, -1, 0, 1, 2, 127) {
	for my $B (-127, -2, -1, 0, 1, 2, 127) {
		my $A8bit = $A & 0xFF;
		my $B8bit = $B & 0xFF;
		spew("$test.in", <<END);
		alloc_cell8(A)
		alloc_cell8(B)
		set8(A, $A8bit)
		set8(B, $B8bit)
		max8s(A, B)
		>B
END
		my $R = ($A > $B) ? $A : $B;
		my $Rout = sprintf("%3d", $R & 0xFF);
		my $Bout = sprintf("%3d", $B8bit);
		capture_ok("bfpp $test.in | bf -D", <<END);
Tape:$Rout $Bout 
         ^^^ (ptr=1)

END
	}
}

unlink_testfiles;
done_testing;
