#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# scan_word - error no arguments
spew("$test.in", "scan_word");
capture_nok("bfpp $test.in", <<END);
$test.in:1:10: error: expected '(' after macro name 'scan_word'
END

# scan_word - error empty arguments
spew("$test.in", "scan_word()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:12: error: macro 'scan_word' expects one NAME
END

# scan_word - error too many arguments
spew("$test.in", "scan_word(A,B)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:12: error: expected ')' at end of macro call, found ','
END

# scan_word - wrong type of arguments
spew("$test.in", "scan_word(42)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: macro 'scan_word' expects one NAME
END

# scan_word - wrong type of arguments
spew("$test.in", "alloc_cell8(A) scan_word(A)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: array 'A' is not an alloc_array result
END

# scan_word - wrong type of arguments
spew("$test.in", "alloc_array16(A) scan_word(A)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: expected ',' in macro argument list
END

# scan_word - read one word
spew("$test.in", <<END);
alloc_array8(STR, 8) set_string(STR, "RUBISH")
scan_word(STR)
END
capture_ok("bfpp $test.in", <<END);
