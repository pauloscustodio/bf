# scan invalid strings
for my $S ("", " ", "hello") {
	spew("$test.in", <<END);
		alloc_cell16(A)
		alloc_array8(S, 10) set_string(S, "$S")
		string_val16s(S, A)
		print_cell16s(A)
END
	capture_ok("bfpp $test.in | bf", "0 ");
}

# scan numbers
for my $S ("0", "-0", "1", "-12 ", "12+23", "-123hello", "32767world", "-32768!") {
	my($A) = $S =~ /(-?\d+)/;
	$A += 0;
	spew("$test.in", <<END);
		alloc_cell16(A)
		alloc_array8(S, 10) set_string(S, "$S")
		string_val16s(S, A)
		print_cell16s(A)
END
	capture_ok("bfpp $test.in | bf", "$A ");
}

unlink_testfiles;
done_testing;
