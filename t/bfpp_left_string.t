#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# left_string - error no arguments
spew("$test.in", "left_string");
capture_nok("bfpp $test.in", <<END);
$test.in:1:12: error: expected '(' after macro name 'left_string'
END

# left_string - error empty arguments
spew("$test.in", "left_string()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: macro 'left_string' expects DST, SRC strings and size
END

# left_string - error too many arguments
spew("$test.in", "left_string(A,B,C,D)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: expected ')' at end of macro call, found ','
END

# left_string - wrong type of arguments
spew("$test.in", "left_string(1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: expected ',' in macro argument list
END

# left_string - wrong type of arguments
spew("$test.in", "left_string(1,2,3,4)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: expected ')' at end of macro call, found ','
END

# left_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array8(DST, 5) left_string(DST, 42, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:66: error: macro 'left_string' expects DST, SRC strings and size
END

# left_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array8(DST, 5) left_string(42, SRC, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:66: error: macro 'left_string' expects DST, SRC strings and size
END

# left_string - wrong type of arguments
spew("$test.in", "alloc_array16(SRC, 5) alloc_array8(DST, 5) left_string(DST, SRC,1 )");
capture_nok("bfpp $test.in", <<END);
$test.in:1:68: error: array 'SRC' is not a alloc_array8() array
END

# left_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array16(DST, 5) left_string(DST, SRC,1 )");
capture_nok("bfpp $test.in", <<END);
$test.in:1:68: error: array 'DST' is not a alloc_array8() array
END

# left_string - wrong type of arguments
spew("$test.in", "alloc_cell8(SRC) alloc_array8(DST, 5) left_string(DST, SRC, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'SRC' is not an alloc_array result
END

# left_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_cell8(DST) left_string(DST, SRC, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'DST' is not an alloc_array result
END

# left_string - use as reserved word
spew("$test.in", "#define left_string 1");
capture_nok("bfpp $test.in", <<END);
$test.in:1:9: error: cannot define macro 'left_string': reserved word
END

# alloc_array8, set string
spew("$test.in", <<END);
alloc_cell8(SIZE)  set8(SIZE, 1)
alloc_array8(DST, 5)
alloc_array8(SRC, 5)
left_string(DST, SRC, SIZE)
END
capture_ok("bfpp $test.in", <<END);
