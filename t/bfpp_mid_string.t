#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# mid_string - error no arguments
spew("$test.in", "mid_string");
capture_nok("bfpp $test.in", <<END);
$test.in:1:11: error: expected '(' after macro name 'mid_string'
END

# mid_string - error empty arguments
spew("$test.in", "mid_string()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: macro 'mid_string' expects DST, SRC strings, start and size
END

# mid_string - error too many arguments
spew("$test.in", "mid_string(A,B,C,D,E)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:19: error: expected ')' at end of macro call, found ','
END

# mid_string - wrong type of arguments
spew("$test.in", "mid_string(1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:13: error: expected ',' in macro argument list
END

# mid_string - wrong type of arguments
spew("$test.in", "mid_string(1,2,3,4,5)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:19: error: expected ')' at end of macro call, found ','
END

# mid_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array8(DST, 5) mid_string(DST, 42, 1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:68: error: macro 'mid_string' expects DST, SRC strings, start and size
END

# mid_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array8(DST, 5) mid_string(42, SRC, 1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:68: error: macro 'mid_string' expects DST, SRC strings, start and size
END

# mid_string - wrong type of arguments
spew("$test.in", "alloc_array16(SRC, 5) alloc_array8(DST, 5) mid_string(DST, SRC, 1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:70: error: array 'SRC' is not a alloc_array8() array
END

# mid_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_array16(DST, 5) mid_string(DST, SRC, 1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:70: error: array 'DST' is not a alloc_array8() array
END

# mid_string - wrong type of arguments
spew("$test.in", "alloc_cell8(SRC) alloc_array8(DST, 5) mid_string(DST, SRC, 1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'SRC' is not an alloc_array result
END

# mid_string - wrong type of arguments
spew("$test.in", "alloc_array8(SRC, 5) alloc_cell8(DST) mid_string(DST, SRC, 1, 1)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'DST' is not an alloc_array result
END

# mid_string - use as reserved word
spew("$test.in", "#define mid_string 1");
capture_nok("bfpp $test.in", <<END);
$test.in:1:9: error: cannot define macro 'mid_string': reserved word
END

# alloc_array8, set string
spew("$test.in", <<END);
alloc_cell8(START)  set8(START, 1)
alloc_cell8(SIZE)   set8(SIZE, 10)
alloc_array8(DST, 5)
alloc_array8(SRC, 5)
mid_string(DST, SRC, START, SIZE)
END
capture_ok("bfpp $test.in", <<END);
