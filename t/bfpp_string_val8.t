# scan invalid strings
for my $S ("", " ", "-", "-1", "hello") {
	spew("$test.in", <<END);
		alloc_cell8(A)
		alloc_array8(S, 10) set_string(S, "$S")
		string_val8(S, A)
		print_cell8(A)
END
	capture_ok("bfpp $test.in | bf", "0 ");
}

# scan numbers
for my $S ("0", "1", "12 ", "12+23", "123hello", "127world", "255!") {
	my($A) = $S =~ /(\d+)/;
	$A += 0;
	spew("$test.in", <<END);
		alloc_cell8(A)
		alloc_array8(S, 10) set_string(S, "$S")
		string_val8(S, A)
		print_cell8(A)
END
	capture_ok("bfpp $test.in | bf", "$A ");
}

unlink_testfiles;
done_testing;
