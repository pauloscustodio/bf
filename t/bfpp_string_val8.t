#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# string_val8 - error no arguments
spew("$test.in", "string_val8");
capture_nok("bfpp $test.in", <<END);
$test.in:1:12: error: expected '(' after macro name 'string_val8'
END

# string_val8 - error empty arguments
spew("$test.in", "string_val8()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: macro 'string_val8' expects one NAME and one cell
END

# string_val8 - error too many arguments
spew("$test.in", "string_val8(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: expected ')' at end of macro call, found ','
END

# string_val8 - wrong type of arguments
spew("$test.in", "string_val8(0, 2)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: macro 'string_val8' expects one NAME and one cell
END

# string_val8 - wrong type of arguments
spew("$test.in", "alloc_cell8(A) string_val8(A, 2)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: array 'A' is not an alloc_array result
END

# string_val8 - wrong type of arguments
spew("$test.in", "alloc_array16(A, 10) string_val8(A, 2)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:39: error: array 'A' is not a alloc_array8() array
END

# string_val8 - print the given cells
spew("$test.in", <<END);
alloc_cell8(A)
alloc_array8(S, 10) set_string(S, "0")
string_val8(S, A)
END
capture_ok("bfpp $test.in", <<END);
