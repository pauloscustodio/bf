#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# min8 - error no arguments
spew("$test.in", "min8");
capture_nok("bfpp $test.in", <<END);
$test.in:1:5: error: expected '(' after macro name 'min8'
END

# min8 - error empty arguments
spew("$test.in", "min8()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:7: error: macro 'min8' expects 2 arguments
END

# min8 - error too many arguments
spew("$test.in", "min8(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:9: error: expected ')' at end of macro call, found ','
END

# min8(a,b)
spew("$test.in", <<END);
alloc_cell8(A)
alloc_cell8(B)
min8(A,B)
END
