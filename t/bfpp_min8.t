# run min8(a,b)
for my $A (0, 1, 2) {
	for my $B (0, 1, 2) {
		spew("$test.in", <<END);
		alloc_cell8(A)
		alloc_cell8(B)
		set8(A, $A)
		set8(B, $B)
		min8(A, B)
		>B
END
		my $R = ($A < $B) ? $A : $B;
		capture_ok("bfpp $test.in | bf -D", <<END);
