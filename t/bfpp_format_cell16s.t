#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# format_cell16s - error no arguments
spew("$test.in", "format_cell16s");
capture_nok("bfpp $test.in", <<END);
$test.in:1:15: error: expected '(' after macro name 'format_cell16s'
END

# format_cell16s - error empty arguments
spew("$test.in", "format_cell16s()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:17: error: macro 'format_cell16s' expects one NAME and one cell
END

# format_cell16s - error too many arguments
spew("$test.in", "format_cell16s(A,B,C)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:19: error: expected ')' at end of macro call, found ','
END

# format_cell16s - print the given cells
spew("$test.in", <<END);
alloc_array8(S, 10)
alloc_cell16(A)
format_cell16s(S, A)
END
capture_ok("bfpp $test.in", <<END);
