#!/usr/bin/env perl

BEGIN { use lib 't'; require 'testlib.pl'; }

use Modern::Perl;

# format_cell16 - error no arguments
spew("$test.in", "format_cell16");
capture_nok("bfpp $test.in", <<END);
$test.in:1:14: error: expected '(' after macro name 'format_cell16'
END

# format_cell16 - error empty arguments
spew("$test.in", "format_cell16()");
capture_nok("bfpp $test.in", <<END);
$test.in:1:16: error: macro 'format_cell16' expects one NAME and one cell
END

# format_cell16 - error too many arguments
spew("$test.in", "format_cell16(A,B,c)");
capture_nok("bfpp $test.in", <<END);
$test.in:1:18: error: expected ')' at end of macro call, found ','
END

# format_cell16 - print the given cells
spew("$test.in", <<END);
alloc_array8(S, 10)
alloc_cell16(A)
format_cell16(S, A)
END
capture_ok("bfpp $test.in", <<END);
