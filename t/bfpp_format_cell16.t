# print numbers
for my $A (0, 1, 12, 123, 1234, 12345, 32767, 65535) {
	spew("$test.in", <<END);
		alloc_array8(S, 10+1)
		alloc_cell16(A) set16(A, $A) 
		format_cell16(S, A)
		print_string(S)
END
	capture_ok("bfpp $test.in | bf", "$A ");
}

# buffer too small - no output
for my $A (0, 1, 12, 123, 1234, 12345, 32767, 65535) {
