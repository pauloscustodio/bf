X(Identifier,			"identifier")
X(Number,				"number")
X(StringLiteral,		    "string literal")
X(KeywordLet,			"LET")
X(KeywordInput,			"INPUT")
X(KeywordPrint,			"PRINT")
X(KeywordIf, 			"IF")
X(KeywordThen, 			"THEN")
X(KeywordElse, 			"ELSE")
X(KeywordEndIf,			"ENDIF")
X(KeywordFor, 			"FOR")
X(KeywordTo, 			"TO")
X(KeywordStep, 			"STEP")
X(KeywordNext,			"NEXT")
X(KeywordWhile, 		    "WHILE")
X(KeywordWEnd,			"WEND")
X(KeywordDim,			"DIM")
X(Plus, 				    "+")
X(Minus, 				"-")
X(Star, 				    "*")
X(Slash, 				"/")
X(Caret, 				"^")
X(Ampersand,			    "&")
X(Less, 				    "<")
X(LessEqual, 			"<=")
X(Greater, 				">")
X(GreaterEqual, 		    ">=")
X(Equal, 				"=")
X(NotEqual,				"<>")
X(LParen, 				"(")
X(RParen,				")")
X(KeywordMod, 			"MOD")
X(KeywordShl, 			"SHL")
X(KeywordShr,			"SHR")
X(KeywordNot, 			"NOT")
X(KeywordAnd, 			"AND")
X(KeywordOr, 			"OR")
X(KeywordXor,			"XOR")
X(KeywordLeftDollar,	    "LEFT$")
X(KeywordMidDollar,		"MID$")
X(KeywordRightDollar,	"RIGHT$")
X(KeywordStrDollar,		"STR$")
X(KeywordLen,			"LEN")
X(KeywordVal,			"VAL")
X(KeywordChrDollar,		"CHR$")
X(KeywordAsc,			"ASC")
X(Colon, 				":")
X(Semicolon, 			";")
X(Comma,				    ",")
X(Newline,				"\\n")
X(EndOfFile,			    "<eof>")

#undef X
